# Cross — environment configuration template
# Copy this file to .env and fill in your keys.
# .env is listed in .gitignore and will never be committed.
#
# Usage:
#   cp .env.example .env
#   # then edit .env with your actual keys

# ── AI API Keys ────────────────────────────────────────────────────────────────
# Each key is optional; only the AI providers you use need to be configured.
# Key names are UPPER_CASE — os.getenv() is case-sensitive on macOS/Linux.

# xAI (Grok)  — https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# Anthropic (Claude)  — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (GPT)  — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Perplexity  — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Google Gemini  — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Discourse ──────────────────────────────────────────────────────────────────
# Discourse credentials are stored as a JSON blob on a single line.
# Use discourse.py to generate this line from a discourse.json file:
#   python3 discourse.py
#
# discourse.json format:
# {
#   "sites": [
#     {
#       "slug": "mysite",
#       "base_url": "https://your-discourse-site.com",
#       "api_key": "your_discourse_api_key",
#       "api_username": "your_discourse_username"
#     }
#   ]
# }
#
# After running discourse.py, a line like the following will be appended here:
# DISCOURSE={"sites":[{"slug":"mysite","base_url":"https://...","api_key":"...","api_username":"..."}]}

# ── TTS (Text-to-Speech) ───────────────────────────────────────────────────────
# Required only if using st-speak or st-voice with a local Piper TTS server.
# Leave blank or omit if not using TTS features.

TTS_HOST=localhost
TTS_PORT=5000
TTS_VOICE=en_US-lessac-medium
